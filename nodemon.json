{
  "signal": "SIGTERM",
  "delay": 1500,
  "ext": "js,json,ejs",
  "watch": [
    "index.js",
    "server.js",
    "modules",
    "routes",
    "controllers",
    "services",
    "config",
    "middlewares",
    "Helpers",
    "views",
    "public"
  ],
  "ignore": [
    "uploads/**",
    "logs/**",
    "*.log",
    "node_modules/**"
  ]
}
