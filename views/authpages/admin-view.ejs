<%- include('includes/header') %>
<body class="g-sidenav-show  bg-gray-100">
  <%- include('includes/sidebar') %>
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
    <!-- Navbar -->
    <%- include('includes/navbar') %>
    <!-- End Navbar -->

    <div class="container-fluid py-2">
      <div class="row">
        <div class="col-12">
          <div class="card my-4">
            <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
              <div class="bg-gradient-info shadow-dark border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
                <h6 class="text-white text-capitalize ps-3">User Details</h6>
                <a href="/admin" class="btn btn-light btn-sm me-3">Back to Users</a>
              </div>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="row mb-4" style="line-height: 250%;">
                <div class="col-md-6">
                  <strong>Name:</strong> <%= admin.name %><br>
                  <strong>Email ID:</strong> <%= admin.email %><br>
                  <strong>Created At:</strong> <%= admin.created_at.toDateString() %>
                </div>

              </div>


            </div>
          </div>
        </div>
      </div>
      <%- include('includes/sub-footer') %>
    </div>
  </main>
  <%- include('includes/config') %>
  <%- include('includes/footer') %>
