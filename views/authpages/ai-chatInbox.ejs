            // textarea.style.transition = "border 150ms ease, box-shadow 150ms ease, border-radius 150ms ease";
            // micButton.style.display = 'none';
            if (inputSection.classList.contains("centered")) {
                inputSection.style.height = "auto";  // Let it grow
                inputSection.classList.add("rectangle");
            }

            
          });
          
        }

  if (inputSection.classList.contains("hide")) {
    // Remove default hero text
    if (defaultMessage) defaultMessage.remove();

    // Show input and put in centered mode
    inputSection.classList.remove("hide");
    inputSection.classList.remove("bottom");
