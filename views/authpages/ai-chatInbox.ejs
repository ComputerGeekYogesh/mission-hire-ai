    );

    // Listen for first user input to move input down
const moveToBottom = () => {
  if (!inputSection.classList.contains("bottom")) {
    inputSection.classList.remove("centered");
    inputSection.classList.add("bottom");
    // chatWindow.classList.add("with-input");
    textareaEl.focus();
    
  }
};

// Key handling: only move when user presses Enter (or Shift+Enter)
const onKeyForMove = (e) => {

  // Shift + Enter → allow newline, DO NOT move input
  if (e.key === "Enter" && e.shiftKey) {
    return; 
  }

  // Enter (normal) → move down + send
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    moveToBottom();
    sendMessage();
    const botMsg = document.querySelector(".bot-message-centered");
    if (botMsg) botMsg.classList.add("hide");
    return;
  }
};

// Attach handler
textareaEl.addEventListener("keydown", onKeyForMove);

  } else {
    // Hide input and restore default (user toggled off)
    inputSection.classList.add("hide");
    inputSection.classList.remove("centered", "bottom");
    chatWindow.classList.remove("with-input");
  }
}



// ensure on appendMessage we scroll to bottom
function appendMessage(text, className) {
  const messageDiv = document.createElement('div');
  messageDiv.className = `message ${className}`;
  messageDiv.textContent = text;
  chatWindow.appendChild(messageDiv);

  // if input is bottom, scroll to bottom; if centered, keep messages visible above input
  setTimeout(() => {
    chatWindow.scrollTop = chatWindow.scrollHeight;
  }, 50);
}

            /* ========== SIDEBAR FUNCTIONALITY ========== */
            // DOM Elements
            const sidebarToggleBtn = document.getElementById('sidebar-toggle-btn');
            const rightSidebar = document.getElementById('right-sidebar');
            const closeSidebarBtn = document.getElementById('close-sidebar');
            const sidebarOverlay = document.getElementById('sidebar-overlay');
            const sidebarList = document.getElementById('sidebar-list');

            // Function to format JSON with syntax highlighting
            function syntaxHighlight(json) {
              if (typeof json != 'string') {
                json = JSON.stringify(json, null, 2);
              }
              json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
              return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
                let cls = 'json-number';
                if (/^"/.test(match)) {
                  if (/:$/.test(match)) {
                    cls = 'json-key';
                  } else {
                    cls = 'json-string';
                  }
                } else if (/true|false/.test(match)) {
                  cls = 'json-boolean';
                } else if (/null/.test(match)) {
                  cls = 'json-null';
                }
                return '<span class="' + cls + '">' + match + '</span>';
              });
            }

            function formatDate(dateStr) {
              const d = new Date(dateStr);
              return d.toLocaleDateString('en-GB', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
              });
            }

            function formatJDText(jd) {
              if (!jd || typeof jd !== 'object') return 'No details available';

              return `
                Job Profile : ${jd.job_profile || '-'}
                Job Description : ${jd.job_description || '-'}
                Experience Required : ${jd.experience_required ?? '-'}
                Number of Questions to Ask : ${jd.number_of_questions ?? '-'}
                List of Contacts : ${(jd.list_of_contacts || []).join(', ') || '-'}
                Name : ${(jd.candidate_name || []).join(', ') || '-'}
                Emails : ${(jd.candidate_email || []).join(', ') || '-'}
                `.trim();
            }

            // Function to create sidebar items
            async function createSidebarItems() {
              sidebarList.innerHTML = '';

              try {
                const res = await fetch('/admin/jd-history');
                const result = await res.json();

                if (!result.success || !result.data.length) {
                  sidebarList.innerHTML = `
                  <li class="sidebar-list-item">
                    <div class="sidebar-list-header">
                      <span>No JD history found (last 7 days)</span>
                    </div>
                  </li>`;
                  return;
                }

                result.data.forEach((item, index) => {
                  const li = document.createElement('li');
                  li.className = 'sidebar-list-item';

                  const header = document.createElement('div');
                  header.className = 'sidebar-list-header';

                  let experienceText = '-';

                  try {
                    const jd =
                      typeof item.enhanced_description === 'string'
                        ? JSON.parse(item.enhanced_description)
                        : item.enhanced_description;

                    const exp = jd?.experience_required;

                    if (exp === 0 || exp === '0') {
                      experienceText = 'Fresher';
                    } else if (typeof exp === 'string') {
                      const lower = exp.toLowerCase();

                      if (
                        lower.includes('fresher') ||
                        lower.includes('no experience')
                      ) {
                        experienceText = 'Fresher';
                      } else {
                        experienceText = `${exp} - Yrs`; // e.g. "2-4"
                      }
                    } else if (typeof exp === 'number') {
                      experienceText = `${exp} - Yrs`;
                    }
                  } catch (e) {
                    console.warn('Experience parse failed');
                  }

                  header.innerHTML = `
                    <div class="title" style="flex-direction: column; align-items: flex-start;">
                      <div style="font-weight: 600;">
                        📄 ${item.title}
                      </div>
                      <div class="sidebar-item-meta">
                        Exp: ${experienceText} | ${formatDate(item.latest_created_at)}
                      </div>
                    </div>
                    <span class="icon">▼</span>
                  `;

                  const contentDiv = document.createElement('div');
                  contentDiv.className = 'sidebar-collapsible-content';

                  const innerDiv = document.createElement('div');
                  innerDiv.className = 'content-inner';

                  const textDiv = document.createElement('div');
                  textDiv.className = 'jd-text-content';

                  let jdObj = {};
                  try {
                    jdObj =
                      typeof item.enhanced_description === 'string'
                        ? JSON.parse(item.enhanced_description)
                        : item.enhanced_description;
                  } catch (e) {
                    console.warn('JD parse failed');
                  }

                  textDiv.innerText = formatJDText(jdObj);

                  const useBtn = document.createElement('button');
                  useBtn.type = 'button';
                  useBtn.className = 'sidebar-history-use-btn';
                  useBtn.textContent = 'Use';

                  useBtn.addEventListener('click', (e) => {
                    e.stopPropagation(); // prevent collapsing
                    applyJsonToChat(item.enhanced_description);
                  });

                  innerDiv.appendChild(useBtn);

                  innerDiv.appendChild(textDiv);
                  contentDiv.appendChild(innerDiv);

                  li.appendChild(header);
                  li.appendChild(contentDiv);

                  header.addEventListener('click', () => {
                    const expanded = li.classList.contains('expanded');

                    document.querySelectorAll('.sidebar-list-item').forEach(el => {
                      el.classList.remove('expanded');
                    });

                    if (!expanded) {
                      li.classList.add('expanded');
                    }
                  });

                  sidebarList.appendChild(li);
                });

              } catch (err) {
                console.error('Sidebar load failed', err);
              }
            }


            function openSidebar() {
              rightSidebar.classList.add('open');
              sidebarOverlay.classList.add('active');
              document.body.style.overflow = 'hidden';

              createSidebarItems();
            }

            // Function to close sidebar
            function closeSidebar() {
              rightSidebar.classList.remove('open');
              sidebarOverlay.classList.remove('active');
              document.body.style.overflow = ''; // Restore body scroll

              // Close all expanded items
              document.querySelectorAll('.sidebar-list-item').forEach(item => {
                item.classList.remove('expanded');
              });
            }

            // Event listeners for sidebar
            sidebarToggleBtn.addEventListener('click', openSidebar);
            closeSidebarBtn.addEventListener('click', closeSidebar);
            sidebarOverlay.addEventListener('click', closeSidebar);

            // Initialize sidebar on page load
            document.addEventListener('DOMContentLoaded', () => {
              createSidebarItems();
            });

            // Close sidebar with Escape key
            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && rightSidebar.classList.contains('open')) {
                closeSidebar();
              }
            });

            function applyJsonToChat(jsonData) {
              let data = jsonData;

              if (typeof data === 'string') {
                try {
                  data = JSON.parse(data);
                } catch (e) {
                  console.error('Invalid JSON');
                  return;
                }
              }

              // Build formatted text
              let formattedText = '';

              if (data.job_profile) {
                formattedText += `Job Profile : ${data.job_profile}\n`;
              }

              if (data.job_description) {
                formattedText += `Job Description : ${data.job_description}\n`;
              }

              if (data.experience_required) {
                formattedText += `Experience Required : ${data.experience_required}\n`;
              }

              if (data.number_of_questions) {
                formattedText += `Number of Questions to Ask : ${data.number_of_questions}\n`;
              }

              if (data.contacts) {
                formattedText += `List of Contacts : ${Array.isArray(data.contacts) ? data.contacts.join(', ') : data.contacts}\n`;
              }

              if (data.name) {
                formattedText += `Name : ${data.name}\n`;
              }

              if (data.emails) {
                formattedText += `Emails : ${Array.isArray(data.emails) ? data.emails.join(', ') : data.emails}\n`;
              }

              formattedText += `List of Contacts :\n`;
              formattedText += `Name :\n`;
              formattedText += `Emails :\n`;

              // Show input box if hidden
              const inputSection = document.getElementById("input-section");
              const textarea = document.getElementById("user-input");

              if (inputSection.classList.contains("hide")) {
                inputSection.classList.remove("hide");
                inputSection.classList.remove("centered");
                inputSection.classList.add("bottom");
              }

              textarea.value = formattedText.trim();
              textarea.focus();

              textarea.style.height = "auto";
              textarea.style.height = textarea.scrollHeight + "px";

              closeSidebar();
            }


            </script>

