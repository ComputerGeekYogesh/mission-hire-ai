            <script>
              const chatWindow = document.getElementById('chat-window');
              const userInput = document.getElementById('user-input');
              const micButton = document.getElementById('mic-button');
              const sendButton = document.getElementById('send-button');

              // Speech recognition setup
              const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
              let recognition = null;
              let isListening = false;

              if (SpeechRecognition) {
                recognition = new SpeechRecognition();
                recognition.continuous = false;
                recognition.interimResults = true;
                recognition.lang = 'en-US';

                recognition.onstart = function() {
                  isListening = true;
                  micButton.classList.add('listening');
                  appendMessage("Listening... Speak now", 'bot-message');
                };

                recognition.onresult = function(event) {
                  const transcript = Array.from(event.results)
                    .map(result => result[0])
                    .map(result => result.transcript)
                    .join('');

                  userInput.value = transcript;

                  if (event.results[0].isFinal) {
                    setTimeout(() => {
                      sendMessage();
                    }, 1000);
                  }
                };

                recognition.onerror = function(event) {
                  console.error('Speech recognition error:', event.error);
                  appendMessage(`Speech recognition error: ${event.error}`, 'bot-message');
                  stopListening();
                };

                recognition.onend = function() {
                  stopListening();
                };
              } else {
                console.warn('Speech recognition not supported in this browser');
                micButton.style.display = 'none';
              }

              function startListening() {
                if (recognition && !isListening) {
                  try {
                    recognition.start();
                  } catch (error) {
                    console.error('Error starting speech recognition:', error);
                  }
                }
              }

              function stopListening() {
                if (recognition && isListening) {
                  recognition.stop();
                  isListening = false;
                  micButton.classList.remove('listening');
                }
              }

              // Event listeners
              micButton.addEventListener('click', function() {
                if (isListening) {
                  stopListening();
                } else {
                  startListening();
                }
              });

              sendButton.addEventListener('click', sendMessage);

              /* -------------------------
              clientId helper (persistent)
              ------------------------- */
              function getClientId() {
                let id = localStorage.getItem('mission_client_id');
                if (!id) {
                  id = 'client-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2,8);
                  localStorage.setItem('mission_client_id', id);
                }
                return id;
              }

              /* -------------------------
                Updated sendMessage()
                - Always sends messages to /webhook/chat
                - Removes the old direct /chat/confirm calls
                ------------------------- */
              async function sendMessage() {
                const defaultMessage = document.getElementById("default-message");
                const message = userInput.value.trim();
                if (message === '') return;

                if (defaultMessage) defaultMessage.remove();

                appendMessage(message, 'user-message');
                userInput.value = '';
                userInput.style.height = '48px';

                const clientId = getClientId();

                // Typing indicator
                const typingDiv = document.createElement('div');
                typingDiv.className = 'bold-message';

                const thinkingTexts = [
                  "Thinking...",
                  "Analyzing the request...",
                  "Generating the output..."
                ];

                let index = 0;
                let dotCount = 0;

                typingDiv.textContent = thinkingTexts[index];
                
                const interval = setInterval(() => {
                  dotCount = (dotCount + 1) % 4; // cycles 0..3 dots
                  typingDiv.textContent = thinkingTexts[index] + ".".repeat(dotCount);

                  if (dotCount === 3) {
                    if (index < thinkingTexts.length - 1) {
                      index++; // move to next text
                    } else {
                      // Stop at the last text
                      clearInterval(interval);
                    }
                  }

                  chatWindow.scrollTop = chatWindow.scrollHeight;
                }, 500);

                chatWindow.appendChild(typingDiv);
                chatWindow.scrollTop = chatWindow.scrollHeight;

                try {
                  const response = await fetch('/webhook/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, clientId })
                  });

                  const data = await response.json();
                  chatWindow.removeChild(typingDiv);

                  if (data.reply) {
                    appendMessage(data.reply, 'bot-message');
                  }

                  if (data.questions && data.questions.length > 0) {
                  console.log(data);
                  
                  const candidateEmail = data.email;
                  let isPrateekEmail = false;
                  
                  if (candidateEmail) {
                      if (Array.isArray(candidateEmail)) {
                          // Handle array format: check if any email matches prateek@techarchitect.com
                          isPrateekEmail = candidateEmail.some(email => email === 'prateek@techarchitect.com');
                      } else {
                          // Handle string format
                          isPrateekEmail = candidateEmail === 'prateek@techarchitect.com';
                      }
                  }
                  
                  console.log("Email check:", { candidateEmail, isPrateekEmail });
                  
                  let displayQuestions;
                  
                  if (isPrateekEmail) {
                      // For Prateek, show only 3 questions
                      displayQuestions = data.questions.slice(0, 3);
                      console.log(`🎯 Showing ${displayQuestions.length} questions for Prateek`);
                  } else {
                      // For non-Prateek, show all questions (since backend already has the full list)
                      displayQuestions = data.questions;
                      console.log(`👤 Showing ${displayQuestions.length} questions for non-Prateek user`);
                  }

                  // Display the selected questions
                  displayQuestions.forEach((q, i) => {
                      appendMessage(`${i + 1}. ${q}`, 'bot-message');
                  });

                  // Prompt user to confirm
                  setTimeout(() => {
                      appendMessage("Do you want to proceed with these questions? Type 'Yes' to confirm or 'No' to cancel.", 'bot-message highlight-message');
                  }, 300);
              }

                  // Show call results (if any)
                  if (data.callResults && data.callResults.length > 0) {
                    setTimeout(() => {
                      data.callResults.forEach(r => appendMessage(r, 'bot-message'));
                    }, 600);
                  }

                } catch (error) {
                  chatWindow.removeChild(typingDiv);
                  appendMessage('Something went wrong. Please try again.', 'bot-message');
                }
              }

              function handleEnter(event) {
                if (event.key === "Enter" && !event.shiftKey) {
                  event.preventDefault();
                  sendMessage();
                }
              }

              const textarea = document.getElementById("user-input");
              if (textarea) {
                textarea.addEventListener("input", () => {
                  textarea.style.height = "auto";
                  textarea.style.height = textarea.scrollHeight + "px";
                });
              }

              function appendMessage(text, className) {
                const messageDiv = document.createElement('div');
                messageDiv.className = `message ${className}`;
                messageDiv.textContent = text;
                chatWindow.appendChild(messageDiv);
                chatWindow.scrollTop = chatWindow.scrollHeight;
              }

              document.addEventListener("DOMContentLoaded", () => {
                const clientId = getClientId();
                fetch("/webhook/reset", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                  },
                  body: JSON.stringify({clientId })
                })
                  .then(res => res.json())
                  .then(data => {
                    console.log("Chat session reset:", data);
                  })
                  .catch(err => console.error("Reset failed:", err));
              });

              function initiateInterview()
              {
                showHideTextArea();
              }

              function showHideTextArea() {
          const inputSection = document.getElementById("input-section");
          const defaultMessage = document.getElementById("default-message");
          const textareaEl = document.getElementById("user-input");
          const chatWindow = document.getElementById("chat-window");

          const textarea = document.getElementById("user-input");
          
  
        if (textarea) {
          textarea.addEventListener("input", () => {
