<%- include('includes/header') %>
<body class="g-sidenav-show  bg-gray-100">
    <%- include('includes/sidebar') %>
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
    <!-- Navbar -->
    <%- include('includes/navbar') %>
    <!-- End Navbar -->
     <style>
  .custom-card {
    border: 2px solid #cce7ff !important; /* force override */
    border-radius: 12px !important;
    transition: 0.3s ease-in-out;
    background: #f3f3f3a3 !important;
  }
  .custom-card:hover {
    box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
    transform: translateY(-3px);
  }

  .job-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: #000205;
  margin-bottom: 8px;
  text-transform: capitalize;
  white-space: nowrap;       /* Prevents text from wrapping */
  overflow: hidden;          /* Hides overflow text */
  text-overflow: ellipsis;   /* Shows "..." for long text */
}
</style>
    <div class="container-fluid py-2 min-vh-100 ">
      <div class="row">
            <div class="col-12">
                <div class="card ">
                     <div class="card-header p-0 position-relative ">
                        <div class=" border-radius-lg pt-4 pb-2 d-flex justify-content-between align-items-center">
                            <h6 class="text-dark text-capitalize ps-3 mb-0">Permissions List</h6>
                            <a href="/admin/permission-add" class="btn btn-info btn-sm me-4">Add Permission</a>
                        </div>
                    </div>
                </div>
            </div>
           

            <div class="col-12 mt-4">
              <div class="card ">
                <div class="card-body px-0 ml-2">
                  <div class="table-responsive p-3">
                    <table class="table align-items-center mb-0">
                      <thead>
                        <tr>
                          <th class=" text-center text-uppercase text-dark text-xs font-weight-bolder ">Id</th>
                          <th class=" text-center text-uppercase text-dark text-xs font-weight-bolder ">action</th>
                          <th class=" text-center text-uppercase text-dark text-xs font-weight-bolder ">resource</th>
                          <th class="text-center text-uppercase text-dark text-xs font-weight-bolder ">created_at</th>
                          <th class="text-center text-uppercase text-dark text-xs font-weight-bolder ">action</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (permission && permission.length) { %>
                          <% permission.forEach((perm, index) => { %>
                            <tr>
                              <td><p class="text-sm text-center font-weight-bold mb-0 "><%= index + 1 %></p></td>
                              <td><p class="text-sm mb-0 text-center "><%= perm.action %></p></td>
                              <td><p class="text-sm mb-0 text-center "><%= perm.resource %></p></td>
                              <td class="text-center"><span class="text-xs font-weight-bold"><%= new Date(perm.created_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></span></td>
                              <td class="text-end text-center ">
                                <a href="/admin/permission-edit/<%= perm.id %>" class="btn btn-sm btn-info">Edit</a>
                                <!-- <a href="/admin/permission-edit/<%= perm.id %>" class="btn btn-sm btn-danger">Delete</a> -->
                              </td>
                            
                            </tr>
                          <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="5" class="text-center text-muted">No Permission found.</td>
                          </tr>
                        <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
    </div>
      
    <%- include('includes/sub-footer') %>
  </div>
</main>
  <%- include('includes/config') %>
  <!--   Core JS Files   -->
  <%- include('includes/footer') %>

