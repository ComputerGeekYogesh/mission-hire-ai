<%- include('includes/header') %>
<body class="g-sidenav-show  bg-gray-100">
    <%- include('includes/sidebar') %>
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
    <!-- Navbar -->
    <%- include('includes/navbar') %>
    <!-- End Navbar -->
     <style>
  .custom-card {
    border: 2px solid #cce7ff !important; /* force override */
    border-radius: 12px !important;
    transition: 0.3s ease-in-out;
    background: #f3f3f3a3 !important;
  }
  .custom-card:hover {
    box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
    transform: translateY(-3px);
  }

  .job-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: #000205;
  margin-bottom: 8px;
  text-transform: capitalize;
  white-space: nowrap;       /* Prevents text from wrapping */
  overflow: hidden;          /* Hides overflow text */
  text-overflow: ellipsis;   /* Shows "..." for long text */
}
</style>
    <div class="container-fluid py-2 min-vh-100 ">
      <div class="row">
            <div class="col-12">
                <div class="card ">
                     <div class="card-header p-0 position-relative ">
                        <div class="bg-gradient-info border-radius-lg pt-4 pb-2 d-flex justify-content-between align-items-center">
                            <h6 class="text-white text-capitalize ps-3 mb-0">Roles List</h6>
                            <a href="/admin/role-add" class="btn btn-danger btn-sm me-4">Add Role</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
              <% if(success_msg && success_msg.length > 0) { %>
                <div class="alert alert-success text-white"><%= success_msg %></div>
              <% } %>

              <% if(error_msg && error_msg.length > 0) { %>
                <div class="alert alert-danger text-white "><%= error_msg %></div>
              <% } %>

              <% if(error && error.length > 0) { %>
                <div class="alert alert-danger text-white "><%= error %></div>
              <% } %>
            </div>

            <div class="col-12">
              <div class="card ">
                <div class="card-body px-0 ml-2">
                  <div class="table-responsive p-3">
                    <table class="table table-bordered">
                        <thead class="table-light">
                          <tr>
                            <th>Permission</th>
                            <% roles.forEach(role => { %>
                              <th><%= role.name %></th>
                            <% }) %>
                          </tr>
                        </thead>
                        <tbody>
                          <% permissions.forEach(permission => { %>
                            <tr>
                              <td><%= permission.name %></td>
                              <% roles.forEach(role => { %>
                                <td class="text-center">
                                  <input type="checkbox" 
                                    class="perm-checkbox" 
                                    data-role-id="<%= role.id %>" 
                                    data-perm-key="<%= permission.key %>"
                                    <%= rolePermissionMap[role.id]?.[permission.key] ? 'checked' : '' %>>
                                </td>
                              <% }) %>
                            </tr>
                          <% }) %>
                        </tbody>
                      </table>
                      <button id="savePermissions" class="btn btn-primary mt-3">Save Changes</button>
                  </div>
                </div>
              </div>
            </div>
    </div>
    <script src="/js/roles.js"></script>
      
    <%- include('includes/sub-footer') %>
  </div>
</main>
  <%- include('includes/config') %>
  <!--   Core JS Files   -->
  <%- include('includes/footer') %>

