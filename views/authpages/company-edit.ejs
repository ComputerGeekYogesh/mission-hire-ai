              <div class="container mt-5 mb-5">
  <!-- <div class="card shadow-sm border-0 rounded-4"> -->
    <div class="card-body p-5">
      

      <form method="POST" action="/admin/company-edit/<%= company.id %>" class="px-md-4">
        <!-- Company Name -->
        <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <label for="name" class="form-label mb-0 fw-semibold">Account Name</label>
          </div>
          <div class="col-md-9">
            <input 
              type="text" 
              name="name" 
              id="name"
              value="<%= company.name %>" 
              class="form-control form-control-sm outlined-input rounded-3 py-2" 
              placeholder="Enter Account name" 
              required
            >
          </div>
        </div>

        <!-- Company Username -->
        <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <label for="userName" class="form-label mb-0 fw-semibold">Account Username</label>
          </div>
          <div class="col-md-9">
            <input 
              type="text" 
              name="userName" 
              id="userName"
              value="<%= company.userName %>"  
              class="form-control form-control-sm rounded-3 outlined-input py-2" 
              placeholder="Enter Account user name" 
              required
            >
          </div>
        </div>

        <!-- Email -->
        <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <label for="email" class="form-label mb-0 fw-semibold">Email</label>
          </div>
          <div class="col-md-9">
            <input 
              type="email" 
              name="email" 
              id="email"
              value="<%= company.email %>" 
              class="form-control form-control-sm rounded-3 outlined-input py-2" 
              placeholder="Enter email" 
              required
            >
          </div>
        </div>

        <!-- Phone -->
        <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <label for="phone" class="form-label mb-0 fw-semibold">Phone Number</label>
          </div>
          <div class="col-md-9">
            <input 
              type="tel" 
              name="phone" 
              id="phone"
              value="<%= company.phone %>"  
              class="form-control form-control-sm rounded-3 outlined-input py-2" 
              placeholder="Enter phone number" 
              required
            >
          </div>
        </div>

        <!-- Role Selection -->
        <!-- <div class="row mb-4 align-items-center">
          <div class="col-md-3">
            <label for="role" class="form-label mb-0 fw-semibold">Select a Role</label>
          </div>
          <div class="col-md-9">
            <select 
              name="role_id" 
              id="role" 
              class="form-control form-control-sm rounded-3 outlined-input py-2" 
              required
              >
              <option value="" disabled selected>Select a role</option>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>" <%= role.id === company.role_id ? 'selected' : '' %>><%= role.name %></option>
              <% }) %>
            </select>
          </div>
        </div> -->

        <!-- Submit -->
        <div class="row mb-2">
          <div class="col-12 d-flex justify-content-center">
            <button type="submit" class="btn btn-info btn-lg rounded-3 shadow-sm px-5">
              Update
            </button>
          </div>
        </div>
      </form>
    </div>
