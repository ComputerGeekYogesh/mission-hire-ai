<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <link rel="icon" type="image/svg+xml" href="/mission-favicon.svg?v=1" />
  <link rel="apple-touch-icon" href="/mission-favicon.svg?v=1" />

  <title>Mission Hire — Admin Portal</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;0,600;1,500&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://kit.fontawesome.com/42d5adcbca.js" crossorigin="anonymous"></script>
  <link id="pagestyle" href="../assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" />

  <!-- Icons (load before theme CSS) -->
  <link href="/assets/css/nucleo-icons.css" rel="stylesheet" />
  <link href="/assets/css/nucleo-svg.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

  <!-- Main CSS (your core theme) -->
  <link id="pagestyle" href="/assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" />
  <link href="/assets/css/mission-admin-theme.css?v=29" rel="stylesheet" />

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Additional Icon Packs -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">


  <style>
    .btn-info {
    background: linear-gradient(135deg, #D4A24E, #8C6E38);
    border: none;
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 600;
    color: #241B08 !important;
    border-radius: 10px;
    box-shadow: 0px 4px 12px rgba(212, 162, 78, 0.35);
    transition: all 0.3s ease-in-out;
}


.btn-info:hover {
    transform: translateY(-2px);
    box-shadow: 0px 6px 18px rgba(212, 162, 78, 0.45);
    color: #241B08 !important;
}

.btn-info:active {
    transform: scale(0.96);
}

    .json-container {
      display: flex;
      gap: 20px;
      margin-top: 20px;
    }

    .json-block {
      flex: 1;
      background-color: #f9f8f8;
      /* Dark background like editors */
      color: #0a0000;
      /* Light text color */
      padding: 15px;
      border-radius: 8px;
      font-family: 'Courier New', Courier, monospace;
      font-size: 14px;
      overflow-x: auto;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    }

    .json-block h5 {
      color: #000507;
      /* Accent color for heading */
      margin-bottom: 10px;
      font-weight: bold;
    }

    .json-block pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .custom-card {
      border: 2px solid #cce7ff;
      /* Light blue border */
      border-radius: 12px;
      /* Rounded corners */
      transition: 0.3s ease-in-out;
    }

    .custom-card:hover {
      box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
      transform: translateY(-3px);
    }

    #menu li[data-permission] {
      display: none;
    }

    .outlined-input {
      border: 2px solid #e4e6e8;
      /* Blue outline */
      border-radius: 6px;
      /* Optional: Rounded corners */
      /* outline: none;             Removes default browser outline */
    }

    .outlined-input:focus {
      border-color: #e4e6e8;
      /* Info color border */
      box-shadow: 0 0 0 2px rgba(249, 249, 249, 0.25);
      /* Soft glow effect */
      background-color: #ffffff;
      /* Optional: white background on focus */
    }

    body {
      background: #0E0C14;
      font-family: 'Inter', sans-serif;
      color: #F3EFE7;
    }

 
    .card {
      border: none;
      border-radius: 15px;
      background: white;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .stat-title {
      font-size: 0.9rem;
      color: #888;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: bold;
      color: #333;
    }

    .chart-box {
      height: 200px;
    }


    .brand-text {
      font-weight: 600;
      font-size: 1.3rem;
      color: #fff;
    }

    .glow-btn {
      border: none;
      padding: 8px 10px;
      border-radius: 8px;
      cursor: pointer;
      color: white;
      font-size: 14px;
      margin-right: 5px;
      box-shadow: 0 0 5px transparent;
      transition: 0.2s ease-in-out;
    }

    .green {
      background: #28a745;
    }

    .red {
      background: #dc3545;
    }

    .glow-btn:hover {
      box-shadow: 0 0 10px currentColor;
      transform: translateY(-3px);
    }

    .sidebar {
  width: 260px;                     /* set consistent width */
  overflow-y: auto !important;      /* allow vertical scroll */
  overflow-x: hidden !important;    /* REMOVE horizontal scroll */
  white-space: nowrap;              /* prevents items from wrapping */
  scrollbar-width: none;            /* Hide scrollbar in Firefox */
}

.sidebar::-webkit-scrollbar {
  display: none;                    /* Hide scrollbar in Webkit browsers (Chrome, Safari) */
}
  </style>
  <script>document.documentElement.classList.add('mission-admin-theme');</script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.body.classList.add('mission-admin-theme');
    });
  </script>

</head>