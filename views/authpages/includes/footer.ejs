<script>
  let selectedFeedbackId = null;
 
function toggleApprove(id) {
  const approveBtn = document.getElementById(`approve_${id}`);
  const rejectBtn = document.getElementById(`reject_${id}`);
 
  // Toggle green state
  approveBtn.classList.toggle("glow-green");
 
  // If approve becomes active, remove red from reject
  if (approveBtn.classList.contains("glow-green")) {
    rejectBtn.classList.remove("glow-red");
  }
}
 
function toggleReject(id) {
  $('#rejectModal').modal('show');
  const approveBtn = document.getElementById(`approve_${id}`);
  const rejectBtn = document.getElementById(`reject_${id}`);
 
  // Toggle red state
  rejectBtn.classList.toggle("glow-red");
 
  // If reject becomes active, remove green from approve
  if (rejectBtn.classList.contains("glow-red")) {
    approveBtn.classList.remove("glow-green");
  }
}
function submitRejection() {
  const checkedBoxes = document.querySelectorAll('.form-check-input:checked');
 
  if (checkedBoxes.length === 0) {
    alert("Please select at least one reason.");
    return; // stop here
  }
 
  const reasons = Array.from(checkedBoxes).map(cb => cb.value);
  const extraFeedback = document.getElementById("rejectReason").value;
 
  $.ajax({
    url: '/admin/feedback/reject',
    method: 'POST',
    data: {
      id: selectedFeedbackId,
      reason: reasons,
      extraFeedback: extraFeedback,
    },
success: function() {
      Swal.fire({
        icon: 'success',
        title: 'Submitted!',
        text: 'Your feedback has been recorded.',
        confirmButtonText: 'OK'
      });
    },
    error: function() {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'Something went wrong, please try again later.'
      });
    }
  });
}
</script>

 <script>
/**
 * formatAnyPhoneClient
 * - raw: string that may contain +, 00, letters, spaces, etc.
 * - opts.defaultCountry: optional string country code (e.g. "91") to use when no explicit country code exists.
 * Returns formatted string or original raw if it cannot be formatted.
 */
function formatAnyPhoneClient(raw, opts = {}) {
  if (raw === null || raw === undefined) return "";
  const defaultCountry = opts.defaultCountry || ""; // e.g. "91" if you want to default to India

  // keep only digits
  let digits = String(raw).replace(/\D/g, "");

  // if there are leading international-zeros (00) they are already digits; we'll just treat digits uniformly
  // need at least 10 digits for local number
  if (digits.length < 10) {
    // not enough digits to form a 10-digit local number -> return original raw
    return raw;
  }

  // last 10 digits are the local number
  const local = digits.slice(-10);
  const countryCodePart = digits.slice(0, digits.length - 10); // may be empty

  const a = local.slice(0, 3);
  const b = local.slice(3, 6);
  const c = local.slice(6);

  // If country code part exists, use it. Otherwise, use defaultCountry if provided.
  const country = countryCodePart || defaultCountry;

  if (country) {
    return `+${country} (${a}) ${b}-${c}`;
  } else {
    // No country code available: return local number formatted without +country
    return `(${a}) ${b}-${c}`;
  }
}

/**
 * formatAllPhonesOnPage
 * - selector: CSS selector for elements that contain raw phone text (defaults to '.phone')
 * - options: passed to formatAnyPhoneClient
 */
function formatAllPhonesOnPage(selector = '.phone', options = {}) {
  document.querySelectorAll(selector).forEach(el => {
    // Some elements may contain other markup; read only textContent
    const raw = el.dataset.rawPhone !== undefined ? el.dataset.rawPhone : el.textContent;
    const trimmed = raw ? String(raw).trim() : "";
    if (!trimmed) return;

    const formatted = formatAnyPhoneClient(trimmed, options);
    el.textContent = formatted;
  });
}

// Auto-run when DOM ready
document.addEventListener('DOMContentLoaded', () => {
  // If you want to force a default country when there's no code in the DB, pass { defaultCountry: "91" }
  formatAllPhonesOnPage('.phone'); // or formatAllPhonesOnPage('.phone', { defaultCountry: "91" });
});
</script>

