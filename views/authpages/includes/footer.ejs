<!-- reject  modal -->
    <div class="modal" id="rejectModal">
  <div class="modal-dialog">
    <div class="modal-content">
     
      <div class="modal-header">
        <h5 class="modal-title">Tell us what went wrong?</h5>
      </div>
 
      <div class="modal-body">
 
        <label><strong>Select reason(s)</strong></label>
      <div class="form-check">
  <input class="form-check-input" type="checkbox" name="rejectReason[]" value="Inaccurate" id="reason1" required>
  <label class="form-check-label" for="reason1">Inaccurate</label>
</div>
 
<div class="form-check">
  <input class="form-check-input" type="checkbox" name="rejectReason[]" value="Incomplete" id="reason2">
  <label class="form-check-label" for="reason2">Incomplete</label>
</div>
 
<div class="form-check">
  <input class="form-check-input" type="checkbox" name="rejectReason[]" value="Biased, toxic, or harmful" id="reason3">
  <label class="form-check-label" for="reason3">Biased, toxic, or harmful</label>
</div>
 
<div class="form-check">
  <input class="form-check-input" type="checkbox" name="rejectReason[]" value="Inappropriate tone or style" id="reason4">
  <label class="form-check-label" for="reason4">Inappropriate tone or style</label>
</div>
 
<div class="form-check">
  <input class="form-check-input" type="checkbox" name="rejectReason[]" value="Other" id="reason5">
  <label class="form-check-label" for="reason5">Other</label>
</div>
 
        <br>
        <label><strong>Tell us more</strong></label>
        <textarea id="rejectReason" class="form-control" placeholder="Give feedback..."></textarea>
 
      </div>
 
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button onclick="submitRejection()" class="btn btn-primary">Submit</button>
      </div>
 
    </div>
  </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
const cards = document.querySelectorAll('.llm-card');
const modal = document.getElementById('modal');
const modalTitle = document.getElementById('modalTitle');
 
const apiKeyInput = document.getElementById('apiKeyInput');
const baseUrlInput = document.getElementById('baseUrlInput');
const modelInput = document.getElementById('modelSelect');
 
 
// All LLaMA models
const llamaModels = [
  { value: "llama-3.2-1b", label: "LLaMA 3.2 - 1B" },
  { value: "llama-3.1-8b-instruct", label: "LLaMA 3.1 - 8B Instruct" },
  { value: "llama-3.1-70b-instruct", label: "LLaMA 3.1 - 70B Instruct" },
  { value: "llama-3.2-3b", label: "LLaMA 3.2 - 3B" },
  { value: "llama-guard-3", label: "LLaMA Guard 3" }
];
 
cards.forEach(card => {
  card.addEventListener('click', () => {
 
    document.querySelector('.llm-card.selected')?.classList.remove('selected');
    card.classList.add('selected');
 
    const llmName = card.dataset.llm;
    modalTitle.textContent = `${llmName} Configuration`;
    modal.style.display = 'grid';
 
    // RESET fields
    apiKeyInput.value = "";
    baseUrlInput.value = "";
    modelInput.innerHTML = ""; // clear dropdown
 
    // DYNAMIC LOGIC
    if (llmName === "LLaMA") {
 
      baseUrlInput.placeholder = "eg, https://api.llama-provider.com";
 
      // Insert models dynamically
      llamaModels.forEach(model => {
        const option = document.createElement("option");
        option.value = model.value;
        option.textContent = model.label;
        modelInput.appendChild(option);
      });
 
    } else {
baseUrlInput.placeholder = "https://example.com";
      // Placeholder when NOT LLaMA
      const option = document.createElement("option");
      option.textContent = "Select Model";
      option.disabled = true;
      option.selected = true;
      modelInput.appendChild(option);
    }
  });
});
// Close modal
function closeModal() {
    modal.style.display = 'none';
}
 
// Close on background click
modal.addEventListener('click', (e) => {
  if (e.target === modal) closeModal();
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const successMsg = <%- JSON.stringify(Array.isArray(success_msg) ? (success_msg[0] || '') : (success_msg || '')) %>;
  const errorMsg = <%- JSON.stringify(Array.isArray(error_msg) ? (error_msg[0] || '') : (error_msg || '')) %>;
  const skipSwalFlash = Boolean(document.getElementById('callSettingsFlash'));

  const swalBase = {
    background: '#1e293b',
    color: '#f8fafc',
    confirmButtonColor: '#2563eb',
  };

  if (successMsg && !skipSwalFlash) {
    Swal.fire({
      ...swalBase,
      icon: 'success',
      title: 'Success',
      text: successMsg,
      timer: 2500,
      showConfirmButton: false,
    });
  } else if (errorMsg && !skipSwalFlash) {
    Swal.fire({
      ...swalBase,
      icon: 'error',
      title: 'Error',
      text: errorMsg,
      timer: 3000,
      showConfirmButton: false,
    });
  }
});
</script>

<script>
  document.getElementById('change_account').addEventListener('change', function() {
    const companyId = this.value;
    fetch('/admin/update-role-session', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ company_id: companyId })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        // Optionally refresh the page to apply the new role
        location.reload();
      } else {
        alert('Failed to update role in session.');
      }
    })
    .catch(err => console.error('Error:', err));
  });
  </script>


