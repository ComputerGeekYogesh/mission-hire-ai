<%- include('includes/header') %>
<body class="g-sidenav-show  bg-gray-100">
  
    <%- include('includes/sidebar') %>
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
    <!-- Navbar -->
    <%- include('includes/navbar') %>
    <!-- End Navbar -->
    <div class="container-fluid py-2">
      <div class="row ">
        
        <div class="row g-3">
          <div class="col-lg-4 col-md-6 mb-xl-0 mb-2 ">
            <div class="card">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <p class="text-sm mb-0 text-capitalize">Total company</p>
                    <h4 class="mb-0"><%= stats.company %></h4>
                  </div>
                  <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">business_center</i>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-xl-4 col-sm-6 mb-xl-0 mb-2">
            <div class="card">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <p class="text-sm mb-0 text-capitalize">Verified company</p>
                    <h4 class="mb-0"><%= stats.activeCompany %></h4>
                  </div>
                  <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">business_center</i>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-xl-4 col-sm-6 mb-xl-0 mb-2">
            <div class="card">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <p class="text-sm mb-0 text-capitalize">Total Jobs</p>
                    <h4 class="mb-0"><%= stats.jobs %></h4>
                  </div>
                  <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">business_center</i>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <div class="row mt-1 g-3">
          <div class="col-xl-4 col-sm-6 mb-xl-0 mb-4">
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <p class="text-sm mb-0 text-capitalize">Total Candidates</p>
                  <h4 class="mb-0"><%= stats.candidates %></h4>
                </div>
                <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                  <i class="material-symbols-rounded opacity-10">person</i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-4 col-sm-6 mb-xl-0 mb-4">
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <p class="text-sm mb-0 text-capitalize">Pass Candidates</p>
                  <h4 class="mb-0"><%= stats.filtered %></h4>
                </div>
                <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                  <i class="material-symbols-rounded opacity-10">trophy</i>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-4 col-sm-6">
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <p class="text-sm mb-0 text-capitalize">Failed Candidates</p>
                  <h4 class="mb-0"><%= stats.fail %></h4>
                </div>
                <div class="icon icon-md icon-shape bg-gradient-info shadow-dark shadow text-center border-radius-lg">
                  <i class="material-symbols-rounded opacity-10">person</i>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
      <div class="row">
        <div class="col-lg-4 col-md-6 mt-4 mb-4">
          <div class="card">
            <div class="card-body">
              <h6 class="mb-0 ">Added Jobs</h6>
              <p class="text-sm ">Last 7 days Added Jobs</p>
              <div class="pe-2">
                <div class="chart">
                  <canvas id="chart-bars" class="chart-canvas" height="170"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6 mt-4 mb-4">
          <div class="card ">
            <div class="card-body">
              <h6 class="mb-0 "> Added Candidates </h6>
              <p class="text-sm ">Last 7 days Added Candidates.</p>
              <div class="pe-2">
                <div class="chart">
                  <canvas id="chart-line" class="chart-canvas" height="170"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mt-4 mb-3">
          <div class="card">
            <div class="card-body">
              <h6 class="mb-0 ">Passed Candidates</h6>
              <p class="text-sm ">Last 7 days Pass Candidates.</p>
              <div class="pe-2">
                <div class="chart">
                  <canvas id="chart-line-tasks" class="chart-canvas" height="170"></canvas>
                </div>
              </div>
              <!-- <hr class="dark horizontal">
              <div class="d-flex ">
                <i class="material-symbols-rounded text-sm my-auto me-1">schedule</i>
                <p class="mb-0 text-sm">just updated</p>
              </div> -->
            </div>
          </div>
        </div>
      </div>
      <div class="row mb-4">
        <div class="col-lg-8 col-md-6 mb-md-0 mb-4">
          <div class="card">
            <div class="card-header pb-0">
              <div class="row">
                <div class="col-lg-6 col-7">
                  <h6>Recent Jobs</h6>
                </div>
                <div class="col-lg-6 col-5 my-auto text-end">
                  <div class="dropdown float-lg-end pe-4">
                    <a class="cursor-pointer" id="dropdownTable" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="fa fa-ellipsis-v text-secondary"></i>
                    </a>
                    <ul class="dropdown-menu px-2 py-3 ms-sm-n4 ms-n5" aria-labelledby="dropdownTable">
                      <li><a class="dropdown-item border-radius-md" href="javascript:;">Action</a></li>
                      <li><a class="dropdown-item border-radius-md" href="javascript:;">Another action</a></li>
                      <li><a class="dropdown-item border-radius-md" href="javascript:;">Something else here</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <div class="card-body px-0 pb-2">
              <div class="table-responsive">
                <table class="table align-items-center mb-0">
                  <thead>
                    <tr>
                      <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Job Titles</th>
                      <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Candidates</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentJobs.forEach(job => { %>
                      <tr>
                        <td>
                          <div class="d-flex px-2 py-1">
                            <div>
                              <img src="/assets/img/small-logos/logo-xd.svg" class="avatar avatar-sm me-3" alt="xd">
                            </div>
                            <div class="d-flex flex-column justify-content-center">
                              <h6 class="mb-0 text-sm"><%= job.title %></h6>
                              <p class="text-xs text-secondary mb-0">Posted on: <%= new Date(job.created_at).toLocaleDateString() %></p>
                            </div>
                          </div>
                        </td>
                        <td>
                          <span class="text-sm fw-bold">
                            <%= job.total_candidates %> Candidates
                          </span>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                  
                </table>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-4 col-md-6">
          <div class="card h-100">
            <div class="card-header pb-0">
              <h6>Calls Overview</h6>
              <p class="text-sm">
                <i class="fa fa-arrow-up text-success" aria-hidden="true"></i>
                <!-- <span class="font-weight-bold">24%</span> this month -->
                <!-- <span class="font-weight-bold">24%</span> this month -->
              </p>
            </div>
            <div class="card-body p-3">
              <div class="timeline timeline-one-side">
                <div class="timeline-block mb-3">
                  <span class="timeline-step">
                    <i class="material-symbols-rounded text-primary text-gradient">business_center</i>
                  </span>
                  <div class="timeline-content">
                    <h6 class="text-dark text-sm font-weight-bold mb-0"><%= stats.callOverviewJobs %>, Jobs</h6>
                    <!-- <h6 class="text-dark text-sm font-weight-bold mb-0"><%= stats.jobs %>, Jobs</h6> -->
                    <p class="text-secondary font-weight-bold text-xs mt-1 mb-0"><%= currentMonthYear %></p>
                  </div>
                </div>
                <div class="timeline-block mb-3">
                  <span class="timeline-step">
                    <i class="material-symbols-rounded text-success text-gradient">person</i>
                  </span>
                  <div class="timeline-content">
                    <h6 class="text-dark text-sm font-weight-bold mb-0">New <%= stats.callOverviewCandidates %> candidates</h6>
                    <!-- <h6 class="text-dark text-sm font-weight-bold mb-0">New  <%= stats.candidates %> candidates</h6> -->
                    <p class="text-secondary font-weight-bold text-xs mt-1 mb-0"><%= currentMonthYear %></p>
                  </div>
                </div>
                <div class="timeline-block mb-3">
                  <span class="timeline-step">
                    <i class="material-symbols-rounded text-info text-gradient">person</i>
                  </span>
                  <div class="timeline-content">
                    <h6 class="text-dark text-sm font-weight-bold mb-0">Interview call done for <%= stats.callOverviewCallDoneCandidates %> candidates</h6>
                    <!-- <h6 class="text-dark text-sm font-weight-bold mb-0">Interview call done for <%= stats.filtered %> candidates</h6> -->
                    <p class="text-secondary font-weight-bold text-xs mt-1 mb-0"><%= currentMonthYear %></p>
                  </div>
                </div>
                
                <div class="timeline-block mb-3">
                  <span class="timeline-step">
                    <i class="material-symbols-rounded text-primary text-gradient">person</i>
                  </span>
                  <div class="timeline-content">
                    <h6 class="text-dark text-sm font-weight-bold mb-0">Failed candidates <%= stats.calloverviewFailedCandidates %></h6>
                    <!-- <h6 class="text-dark text-sm font-weight-bold mb-0">Interview call pending for 0 candidates</h6> -->
                    <p class="text-secondary font-weight-bold text-xs mt-1 mb-0"><%= currentMonthYear %></p>
                  </div>
                </div>
                <div class="timeline-block">
                  <span class="timeline-step">
                    <i class="material-symbols-rounded text-dark text-gradient">trophy</i>
                  </span>
                  <div class="timeline-content">
                    <!-- <h6 class="text-dark text-sm font-weight-bold mb-0">Selected candidates <%= stats.calloverviewPassCandidates %></h6> -->
                    <h6 class="text-dark text-sm font-weight-bold mb-0">Selected candidates <%= stats.calloverviewPassCandidates %></h6>
                    <p class="text-secondary font-weight-bold text-xs mt-1 mb-0"><%= currentMonthYear %></p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
<script src="../assets/js/plugins/chartjs.min.js"></script>

<script>
  const labels = <%- JSON.stringify(lastSeavenDaysJobs.map(item => item.day_name.charAt(0))) %>;
  const jobCounts = <%- JSON.stringify(lastSeavenDaysJobs.map(item => item.job_count)) %>;

  const clabels = <%- JSON.stringify(lastSeavenDaysCandidates.map(item => item.day_name.charAt(0))) %>;
  const cCounts = <%- JSON.stringify(lastSeavenDaysCandidates.map(item => item.count)) %>;

  const cplabels = <%- JSON.stringify(lastSeavenDaysPassedCandidates.map(item => item.day_name.charAt(0))) %>;
  const cpCounts = <%- JSON.stringify(lastSeavenDaysPassedCandidates.map(item => item.count)) %>;

  console.log('labels:', labels);     // ["T", "W", "T", ...]
  console.log('jobCounts:', jobCounts); // [16, 26, 0, ...]
</script>

  <script>
  var ctx = document.getElementById("chart-bars").getContext("2d");

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: labels,
      datasets: [{
        label: "Added Jobs",
        tension: 0.4,
        borderWidth: 0,
        borderRadius: 4,
        borderSkipped: false,
        backgroundColor: "#43A047",
        data: jobCounts,
        barThickness: 'flex'
      }, ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false,
        }
      },
      interaction: {
        intersect: false,
        mode: 'index',
      },
      scales: {
        y: {
          grid: {
            drawBorder: false,
            display: true,
            drawOnChartArea: true,
            drawTicks: false,
            borderDash: [5, 5],
            color: '#e5e5e5'
          },
          ticks: {
            suggestedMin: 0,
            suggestedMax: 500,
            beginAtZero: true,
            padding: 10,
            font: {
              size: 14,
              lineHeight: 2
            },
            color: "#737373"
          },
        },
        x: {
          grid: {
            drawBorder: false,
            display: false,
            drawOnChartArea: false,
            drawTicks: false,
            borderDash: [5, 5]
          },
          ticks: {
            display: true,
            color: '#737373',
            padding: 10,
            font: {
              size: 14,
              lineHeight: 2
            },
          }
        },
      },
    },
  });


  var ctx2 = document.getElementById("chart-line").getContext("2d");

  new Chart(ctx2, {
    type: "line",
    data: {
      labels: clabels,
      datasets: [{
        label: "Added Candidates",
        tension: 0,
        borderWidth: 2,
        pointRadius: 3,
        pointBackgroundColor: "#43A047",
        pointBorderColor: "transparent",
        borderColor: "#43A047",
        backgroundColor: "transparent",
        fill: true,
        data: cCounts,
        maxBarThickness: 6

      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false,
        }
      },
      interaction: {
        intersect: false,
        mode: 'index',
      },
      scales: {
        y: {
          grid: {
            drawBorder: false,
            display: true,
            drawOnChartArea: true,
            drawTicks: false,
            borderDash: [4, 4],
            color: '#e5e5e5'
          },
          ticks: {
            display: true,
            color: '#737373',
            padding: 10,
            font: {
              size: 12,
              lineHeight: 2
            },
          }
        },
        x: {
          grid: {
            drawBorder: false,
            display: false,
            drawOnChartArea: false,
            drawTicks: false,
            borderDash: [5, 5]
          },
          ticks: {
            display: true,
            color: '#737373',
            padding: 10,
            font: {
              size: 12,
              lineHeight: 2
            },
          }
        },
      },
    },
  });

  var ctx3 = document.getElementById("chart-line-tasks").getContext("2d");

  new Chart(ctx3, {
    type: "line",
    data: {
      labels: cplabels,
      datasets: [{
        label: "Passed Candidates",
        tension: 0,
        borderWidth: 2,
        pointRadius: 3,
        pointBackgroundColor: "#43A047",
        pointBorderColor: "transparent",
        borderColor: "#43A047",
        backgroundColor: "transparent",
        fill: true,
        data: cpCounts,
        maxBarThickness: 6

      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false,
        }
      },
      interaction: {
        intersect: false,
        mode: 'index',
      },
      scales: {
        y: {
          grid: {
            drawBorder: false,
            display: true,
            drawOnChartArea: true,
            drawTicks: false,
            borderDash: [4, 4],
            color: '#e5e5e5'
          },
          ticks: {
            display: true,
            padding: 10,
            color: '#737373',
            font: {
              size: 14,
              lineHeight: 2
            },
          }
        },
        x: {
          grid: {
            drawBorder: false,
            display: false,
            drawOnChartArea: false,
            drawTicks: false,
            borderDash: [4, 4]
          },
          ticks: {
            display: true,
            color: '#737373',
            padding: 10,
            font: {
              size: 14,
              lineHeight: 2
            },
          }
        },
      },
    },
  });
</script>

    </div>
  </main>
  <%- include('includes/config') %>
  </div>

  <%- include('includes/footer') %>
  