<%- include('includes/header') %>
<body class="g-sidenav-show  bg-gray-100">
  <%- include('includes/sidebar') %>
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
    <!-- Navbar -->
    <%- include('includes/navbar') %>
    <!-- End Navbar -->

    <div class="container-fluid py-2">
      <div class="row">
        <div class="col-12">
          <div class="card my-4">
            <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
              <div class="bg-gradient-info shadow-dark border-radius-lg pt-4 pb-3 d-flex justify-content-between align-items-center">
                <h6 class="text-white text-capitalize ps-3">LinkedIn Posts Details </h6>
                <a href="/admin/linkedIn-posts" class="btn btn-light btn-sm me-3">Back to Posts</a>
              </div>
            </div>
            <div class="card-body px-4 pb-4">
              <h4 class="mb-3"><%= post.title %></h4>

              <div class="row mb-4" style="line-height: 250%;">
                <div class="col-md-6">
                  <strong>Requisition ID:</strong> <small><%= post.jobNumber %></small><br>
                  <strong>Entity Url:</strong> <small><%= post.entity_url %></small><br>
                  <strong>Subject:</strong> <small><%= post.subject %></small><br>
                  <strong>status:</strong> <% if (post.status == 1) { %>
                                                <span class="badge badge-sm bg-gradient-success">Done</span>
                                            <% } else { %>
                                                <span class="badge badge-sm bg-gradient-danger">Pending</span>
                                            <% } %><br>
                  <strong>Text:</strong> <small><%= post.text %></small><br>
                  
                                       
                </div>
                
              </div>

              <!-- <div class="row">
                <div class="json-container">
                    <div class="json-block">
                      <h5>Description</h5>
                    </div>
                    <div class="json-block">
                      <h5>Enhanced Description</h5>
                    </div>
                  </div>

              </div> -->
            </div>
          </div>
        </div>
      </div>
      <%- include('includes/sub-footer') %>
    </div>
  </main>
  <%- include('includes/config') %>
  <%- include('includes/footer') %>
