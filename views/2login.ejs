<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(to right, #426488, #61616c);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: white;
      padding: 2rem;
      border-radius: 20px;
      box-shadow: 0 0 20px rgba(0,0,0,0.2);
      max-width: 400px;
      width: 100%;
    }
    .login-card h2 {
      margin-bottom: 1.5rem;
    }
  </style>
</head>
<body>
  <div class="login-card text-center">
    <h2>Admin Login</h2>
    <form action="/send-otp" method="POST">
      <div class="mb-3">
        <input type="email" name="email" class="form-control form-control-lg" placeholder="Enter email" required>
      </div>
      <button type="submit" class="btn btn-secondary btn-lg w-100">Send OTP</button>
    </form>
  </div>
</body>
</html>
