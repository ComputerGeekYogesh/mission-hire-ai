<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
   body {
      background: #f5f5f5; /* Light gray background */
      min-height: 100vh;
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
    }

    .sidebar {
      width: 220px;
      background: #ffffff;
      padding: 1.5rem;
      box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
      height: 100vh;
      position: fixed;
      left: 0;
      top: 0;
    }

    .sidebar h4 {
      color: #0072ff;
      margin-bottom: 2rem;
    }

    .sidebar a {
      display: block;
      color: #333;
      padding: 10px 15px;
      margin-bottom: 10px;
      text-decoration: none;
      border-radius: 8px;
    }

    .sidebar a:hover {
      background: #f0f0f0;
    }

    .main-content {
      margin-left: 220px;
      padding: 2rem;
      flex-grow: 1;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #ffffff;
      color: #333;
      padding: 1rem 2rem;
      border-radius: 12px;
      margin-bottom: 2rem;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .dashboard-card {
      background: #fff;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
    }

    .logout-btn {
      font-size: 0.9rem;
    }

    .sidebar h4 {
    color: #232527;
    margin-bottom: 2rem;
}

  </style>
</head>
<body>

  <%- include('partials/sidebar') %>

  <div class="main-content">
    <%- include('partials/header') %>

    <div class="dashboard-card">
      <h2>Dashboard Overview</h2>
      <p>Welcome to the dashboard.</p>
      <!-- Stats -->
      <div class="row mb-4">
        <div class="col-md-4">
          <div class="card text-white bg-primary mb-3">
            <div class="card-body">
              <h5 class="card-title">Total Users</h5>
              <p class="card-text fs-4"><%= stats.users %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-white bg-success mb-3">
            <div class="card-body">
              <h5 class="card-title">Sales</h5>
              <p class="card-text fs-4"><%= stats.sales %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card text-white bg-warning mb-3">
            <div class="card-body">
              <h5 class="card-title">Profit</h5>
              <p class="card-text fs-4"><%= stats.profit %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Chart -->
      <div class="card mb-4">
        <div class="card-body">
          <canvas id="barChart" height="100"></canvas>
        </div>
      </div>

      <!-- Table -->
      <div class="card">
        <div class="card-header">Recent Users</div>
        <div class="card-body p-0">
          <table class="table table-striped m-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
              </tr>
            </thead>
            <tbody>
              <% recentUsers.forEach(user => { %>
                <tr>
                  <td><%= user.id %></td>
                  <td><%= user.name %></td>
                  <td><%= user.email %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
 <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
