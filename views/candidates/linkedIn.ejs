<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
   body {
      background: #f5f5f5; /* Light gray background */
      min-height: 100vh;
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
    }

    .sidebar {
      width: 220px;
      background: #ffffff;
      padding: 1.5rem;
      box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
      height: 100vh;
      position: fixed;
      left: 0;
      top: 0;
    }

    .sidebar h4 {
      color: #0072ff;
      margin-bottom: 2rem;
    }

    .sidebar a {
      display: block;
      color: #333;
      padding: 10px 15px;
      margin-bottom: 10px;
      text-decoration: none;
      border-radius: 8px;
    }

    .sidebar a:hover {
      background: #f0f0f0;
    }

    .main-content {
      margin-left: 220px;
      padding: 2rem;
      flex-grow: 1;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #ffffff;
      color: #333;
      padding: 1rem 2rem;
      border-radius: 12px;
      margin-bottom: 2rem;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .dashboard-card {
      background: #fff;
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
    }

    .logout-btn {
      font-size: 0.9rem;
    }

    .sidebar h4 {
    color: #232527;
    margin-bottom: 2rem;
}

  </style>
</head>
<body>

  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <%- include('../partials/header') %>

    <div class="dashboard-card">
<div class="container mt-4">
  <h4>Linkedin Candidates - Job ID <%= jobId %></h4>

  <% if (candidates.length) { %>
    <table class="table table-bordered table-hover mt-3">
      <thead>
        <tr>
          <th>Id</th>
          <th>Name</th>
          <th>Email</th>
          <th>experience</th>
        </tr>
      </thead>
      <tbody>
        <% candidates.forEach(c => { %>
          <tr> 
            <td><%= c.id %></td>
            <td><%= c.name %></td>
            <td><%= c.email %></td>
            <td><%= c.experience %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="text-muted mt-3">No Linkedin candidates found for this job.</p>
  <% } %>
</div>
    </div>
  </div>

</body>
</html>